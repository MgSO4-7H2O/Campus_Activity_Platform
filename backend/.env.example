# Backend env example (copy to .env)

NODE_ENV=development
PORT=3000

# Comma-separated allowed origins
CORS_ORIGIN=http://localhost:5173

# Local (host) DB URL when you run postgres via docker compose
DATABASE_URL=postgresql://campus:campus_dev_2026@localhost:5432/campus?schema=public

# Auth (JWT)
# IMPORTANT: production must set a strong secret (>= 32 chars)
JWT_SECRET=dev_only_change_me_please_dev_only_change_me
JWT_ACCESS_TOKEN_TTL_SECONDS=604800
