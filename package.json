{
  "name": "campus-activity-platform",
  "version": "0.1.0",
  "private": true,
  "description": "校园活动管理与报名签到平台",
  "scripts": {
    "lint": "pnpm -r lint",
    "typecheck": "pnpm --filter @campus-activity/shared build && pnpm -r typecheck",
    "test": "pnpm -r test:run",
    "test:e2e": "pnpm --filter @campus-activity/web test:e2e",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "build": "pnpm -r build",
    "dev:backend": "pnpm --filter @campus-activity/server dev",
    "dev:frontend": "pnpm --filter @campus-activity/web dev",
    "format": "prettier -w .",
    "format:check": "prettier -c ."
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
